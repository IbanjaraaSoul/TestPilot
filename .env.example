# --- AI: pick one (or none = mock test cases) ---
# Option A: OpenAI (paid; set your key)
# OPENAI_API_KEY=sk-...

# Option B: Ollama – free, local, no key. Install: https://ollama.com then run e.g. "ollama run llama3.2"
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT_MS=120000

# Optional: port for the POC server (default 3000).
# PORT=3000

# Optional: run Playwright in a visible browser so you can watch steps (default: true).
# PLAYWRIGHT_HEADED=true
# Optional: delay between steps in ms (default 800).
# PLAYWRIGHT_STEP_DELAY_MS=800
